{
    "id": "deepseek",
    "provider": "deepseek",
    "capabilities": ["poll"],
    "parameters": [
        {
            "name": "API_KEY",
            "type": "secret",
            "required": true,
            "label": "API Key",
            "label@zh-Hans": "API 密钥",
            "exposeToScript": true
        },
        {
            "name": "LIMIT",
            "type": "number",
            "required": false,
            "default": "100",
            "label": "Amount Limit",
            "label@zh-Hans": "金额上限",
            "exposeToScript": true
        }
    ],
    "endpoints": {
        "default": "https://api.deepseek.com"
    },
    "poll": {
        "request": {
            "endpoint": "default",
            "path": "/user/balance",
            "method": "GET"
        },
        "map": {}
    },
    "script": "connector.ts"
}
