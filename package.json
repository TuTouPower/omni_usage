{
    "name": "omni_usage",
    "productName": "OmniUsage",
    "version": "1.0.0",
    "description": "Multi-platform AI service usage monitoring desktop app.",
    "main": "out/main/index.js",
    "private": true,
    "scripts": {
        "start": "electron-vite dev",
        "hash:update": "tsx scripts/update-bundled-hashes.ts",
        "prebuild": "tsx scripts/update-bundled-hashes.ts",
        "pretest": "tsx scripts/update-bundled-hashes.ts",
        "build": "electron-vite build",
        "package": "tsx scripts/package-and-run.ts",
        "package:build": "tsx scripts/package-and-run.ts",
        "reload": "tsx scripts/package-and-run.ts --no-build",
        "make": "electron-vite build && electron-builder",
        "make:win": "electron-vite build && electron-builder --win",
        "make:mac": "electron-vite build && electron-builder --mac",
        "make:linux": "electron-vite build && electron-builder --linux",
        "lint": "eslint src tests scripts tests/fixtures *.ts --max-warnings=0",
        "typecheck": "tsc --noEmit",
        "format:check": "prettier --check .",
        "format": "prettier --write .",
        "deadcode": "knip --include files,dependencies",
        "arch": "depcruise src --validate .dependency-cruiser.cjs",
        "schema:export": "tsx scripts/export-schemas.ts",
        "check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm deadcode && pnpm arch",
        "typecheck:plugins": "tsc --noEmit --strict --moduleResolution bundler --esModuleInterop --skipLibCheck assets/plugins/*.ts",
        "security:js": "gitleaks detect --source .",
        "security:sast": "semgrep scan --config=auto src/",
        "test": "vitest run --exclude tests/integration/plugin && vitest run tests/integration/plugin --no-file-parallelism",
        "test:coverage": "vitest run --coverage --exclude tests/integration/plugin && vitest run tests/integration/plugin --no-file-parallelism",
        "test:watch": "vitest",
        "test:e2e": "playwright test --config=playwright.config.ts --project=default",
        "test:visual": "playwright test --config=playwright.config.ts --project=visual",
        "test:visual:update": "playwright test --config=playwright.config.ts --project=visual --update-snapshots",
        "test:packaged": "playwright test --config=playwright.config.ts --project=packaged",
        "test:packaged:vitest": "vitest run tests/packaged_smoke/plugin_execution.test.ts",
        "test:contract:live": "vitest run --config vitest.contract_live.config.mts",
        "test:full": "pnpm test && pnpm test:contract:live",
        "prepare": "husky"
    },
    "keywords": [],
    "author": {
        "name": "tutoupower",
        "email": "49771486+TuTouPower@users.noreply.github.com"
    },
    "license": "AGPL-3.0-only",
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,css}": [
            "prettier --write"
        ]
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "electron",
            "electron-winstaller"
        ],
        "overrides": {
            "tar": ">=6.2.1",
            "tmp": ">=0.2.4"
        }
    },
    "devDependencies": {
        "@playwright/test": "^1.60.0",
        "@tailwindcss/postcss": "^4.3.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/better-sqlite3": "^7.6.13",
        "@types/react": "^19.2.15",
        "@types/react-dom": "^19.2.3",
        "@typescript-eslint/eslint-plugin": "^8.59.4",
        "@typescript-eslint/parser": "^8.59.4",
        "@vitejs/plugin-react": "^4.7.0",
        "@vitest/coverage-v8": "^3.2.4",
        "dependency-cruiser": "^17.4.2",
        "electron": "42.2.0",
        "electron-builder": "^26.15.0",
        "electron-vite": "^5.0.0",
        "eslint": "^9.39.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-import-x": "^4.16.2",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-n": "^18.0.1",
        "eslint-plugin-perfectionist": "^5.9.0",
        "eslint-plugin-promise": "^7.3.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-security": "^4.0.0",
        "eslint-plugin-sonarjs": "^4.0.3",
        "eslint-plugin-unicorn": "^64.0.0",
        "husky": "^9.1.7",
        "jsdom": "^29.1.1",
        "knip": "^6.14.2",
        "lint-staged": "^17.0.5",
        "prettier": "^3.8.3",
        "tailwindcss": "^4.3.0",
        "tslib": "^2.8.1",
        "tsx": "^4.22.3",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.59.4",
        "vite": "^5.4.21",
        "vitest": "^3.2.4"
    },
    "dependencies": {
        "better-sqlite3": "^12.10.0",
        "clsx": "^2.1.1",
        "esbuild": "^0.28.0",
        "lodash": "^4.18.1",
        "lucide-react": "^1.16.0",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "tailwind-merge": "^3.6.0",
        "undici": "^8.3.0",
        "zod": "^4.4.3",
        "zod-to-json-schema": "^3.25.2"
    },
    "packageManager": "pnpm@9.15.4+sha512.b2dc20e2fc72b3e18848459b37359a32064663e5627a51e4c74b2c29dd8e8e0491483c3abb40789cfd578bf362fb6ba8261b05f0387d76792ed6e23ea3b1b6a0"
}
