{
    "name": "omni_usage",
    "productName": "OmniUsage",
    "version": "1.0.0",
    "description": "Multi-platform AI service usage monitoring desktop app.",
    "main": ".vite/build/index.js",
    "private": true,
    "scripts": {
        "start": "electron-forge start",
        "package": "electron-forge package",
        "make": "electron-forge make",
        "publish": "electron-forge publish",
        "lint": "eslint . --max-warnings=0",
        "typecheck": "tsc --noEmit",
        "format:check": "prettier --check .",
        "format": "prettier --write .",
        "deadcode": "knip",
        "arch": "depcruise src --validate .dependency-cruiser.cjs",
        "schema:export": "tsx scripts/export-schemas.ts",
        "check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm deadcode && pnpm arch",
        "test": "vitest run",
        "test:watch": "vitest",
        "prepare": "husky"
    },
    "keywords": [],
    "author": {
        "name": "tutoupower",
        "email": "49771486+TuTouPower@users.noreply.github.com"
    },
    "license": "AGPL-3.0-only",
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,css}": [
            "prettier --write"
        ]
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "electron",
            "electron-winstaller"
        ]
    },
    "devDependencies": {
        "@electron-forge/cli": "^7.11.2",
        "@electron-forge/maker-deb": "^7.11.2",
        "@electron-forge/maker-rpm": "^7.11.2",
        "@electron-forge/maker-squirrel": "^7.11.2",
        "@electron-forge/maker-zip": "^7.11.2",
        "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
        "@electron-forge/plugin-fuses": "^7.11.2",
        "@electron-forge/plugin-vite": "^7.11.2",
        "@electron-forge/shared-types": "^7.11.2",
        "@electron/fuses": "^1.8.0",
        "@tailwindcss/postcss": "^4.3.0",
        "@tailwindcss/vite": "^4.3.0",
        "@types/electron-squirrel-startup": "^1.0.2",
        "@types/react": "^19.2.15",
        "@types/react-dom": "^19.2.3",
        "@typescript-eslint/eslint-plugin": "^8.59.4",
        "@typescript-eslint/parser": "^8.59.4",
        "@vitejs/plugin-react": "^4.7.0",
        "dependency-cruiser": "^17.4.2",
        "electron": "42.2.0",
        "eslint": "^9.39.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-import-x": "^4.16.2",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-n": "^18.0.1",
        "eslint-plugin-perfectionist": "^5.9.0",
        "eslint-plugin-promise": "^7.3.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-security": "^4.0.0",
        "eslint-plugin-sonarjs": "^4.0.3",
        "eslint-plugin-unicorn": "^64.0.0",
        "husky": "^9.1.7",
        "knip": "^6.14.2",
        "lint-staged": "^17.0.5",
        "prettier": "^3.8.3",
        "tailwindcss": "^4.3.0",
        "tsx": "^4.22.3",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.59.4",
        "vite": "^5.4.21",
        "vitest": "^3.2.4"
    },
    "dependencies": {
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "electron-squirrel-startup": "^1.0.1",
        "lucide-react": "^1.16.0",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "tailwind-merge": "^3.6.0",
        "zod": "^4.4.3",
        "zod-to-json-schema": "^3.25.2"
    }
}
