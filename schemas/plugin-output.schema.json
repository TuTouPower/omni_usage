{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "schemaVersion": {
            "type": "number"
        },
        "updatedAt": {
            "type": "string"
        },
        "items": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "used": {
                        "type": "number"
                    },
                    "limit": {
                        "type": "number"
                    },
                    "displayStyle": {
                        "type": "string",
                        "enum": ["percent", "ratio"]
                    },
                    "resetAt": {
                        "type": "string"
                    },
                    "status": {
                        "type": "string",
                        "enum": ["normal", "warning", "critical", "unknown"],
                        "default": "unknown"
                    },
                    "color": {
                        "type": "string",
                        "enum": ["blue", "green", "yellow", "orange", "red"]
                    }
                },
                "required": ["id", "name", "used", "limit", "displayStyle"],
                "additionalProperties": false
            }
        },
        "badge": {
            "type": "string"
        },
        "chart": {
            "type": "object",
            "properties": {
                "kind": {
                    "type": "string"
                },
                "period": {
                    "type": "string"
                },
                "bucketUnit": {
                    "type": "string",
                    "enum": ["hour", "day"]
                },
                "buckets": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "label": {
                                "type": "string"
                            },
                            "segments": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "model": {
                                            "type": "string"
                                        },
                                        "tokens": {
                                            "type": "number"
                                        }
                                    },
                                    "required": ["model", "tokens"],
                                    "additionalProperties": false
                                }
                            }
                        },
                        "required": ["label", "segments"],
                        "additionalProperties": false
                    }
                },
                "message": {
                    "type": "string"
                }
            },
            "required": ["kind", "period", "bucketUnit", "buckets"],
            "additionalProperties": false
        }
    },
    "required": ["schemaVersion", "updatedAt", "items"],
    "additionalProperties": false
}
